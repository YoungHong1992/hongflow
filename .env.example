COMPOSE_PROJECT_NAME=hongflow
NODE_ENV=development
APP_SECRET=change-me-in-production
POSTGRES_DB=hongflow
POSTGRES_USER=hongflow
POSTGRES_PASSWORD=hongflow
DATABASE_URL=postgresql://hongflow:hongflow@postgres:5432/hongflow
REDIS_URL=redis://redis:6379
API_HOST=0.0.0.0
API_PORT=3001
WEB_PORT=3000
VITE_API_BASE_URL=http://localhost:3001/api
RUN_MIGRATIONS=true
WORKER_CONCURRENCY=2
UPLOAD_DIR=./data/uploads
EXPORT_DIR=./data/exports
IMAGE_PROVIDER=mock
OPENAI_API_KEY=
